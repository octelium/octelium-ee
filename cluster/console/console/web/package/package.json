{
  "name": "octelium-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "SEE LICENSE in LICENSE",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "build-dev": "tsc && vite build --mode development",
    "build-staging": "tsc && vite build --mode staging",
    "protoc-gen-user": "npx protoc --ts_out ./tmp --ts_opt long_type_number --proto_path ../../../../../ apis/protobuf/main/userv1/userv1.proto",
    "protoc-gen-core": "npx protoc --ts_out ./tmp --ts_opt long_type_number --proto_path ../../../../../ apis/protobuf/main/corev1/corev1.proto",
    "protoc-gen-ee": "npx protoc --ts_out ./tmp --ts_opt long_type_number --proto_path ../../../../../ apis/protobuf/main/enterprisev1/enterprisev1.proto",
    "protoc-gen-meta": "npx protoc --ts_out ./tmp --ts_opt long_type_number --proto_path ../../../../../ apis/protobuf/main/metav1/metav1.proto",
    "protoc-gen-auth": "npx protoc --ts_out ./tmp --ts_opt long_type_number --proto_path ../../../../../ apis/protobuf/main/authv1/authv1.proto",
    "protoc-gen-visibility": "npx protoc --ts_out ./tmp --ts_opt long_type_number --proto_path ../../../../../ apis/protobuf/main/visibilityv1/visibilityv1.proto",
    "protoc-gen-visibility-m": "npx protoc --ts_out ./tmp --ts_opt long_type_number --proto_path ../../../../../ apis/protobuf/main/visibilityv1/meta/vmetav1.proto",
    "protoc-gen-visibility-n": "npx protoc --ts_out ./tmp --ts_opt long_type_number --proto_path ../../../../../ apis/protobuf/main/visibilityv1/core/vcorev1.proto",
    "protoc-gen": "mkdir -p ./tmp/apis/protobuf && npm run protoc-gen-meta && npm run protoc-gen-user && npm run protoc-gen-core && npm run protoc-gen-auth && npm run protoc-gen-ee && npm run protoc-gen-visibility && npm run protoc-gen-visibility-m && npm run protoc-gen-visibility-n",
    "protoc-cp": "cp -r ./tmp/apis/protobuf/main/metav1 ./src/apis && cp -r ./tmp/apis/protobuf/main/userv1 ./src/apis && cp -r ./tmp/apis/protobuf/main/corev1 ./src/apis && cp -r ./tmp/apis/protobuf/main/authv1 ./src/apis && cp -r ./tmp/apis/protobuf/main/enterprisev1 ./src/apis && cp -r ./tmp/apis/protobuf/main/visibilityv1 ./src/apis",
    "protoc-fix": "find ./src/apis -name '*.ts' -exec sed -i s#../../../../google/protobuf#../google/protobuf#g {} +",
    "cleanup-pf": "find ./src/apis -type f -name '*.proto' -exec rm {} +",
    "protoc": "npm run protoc-gen && npm run protoc-cp && npm run protoc-fix && npm run cleanup-pf"
  },
