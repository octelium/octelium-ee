{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/ComponentLog",
    "definitions": {
        "ComponentLog": {
            "properties": {
                "apiVersion": {
                    "type": "string",
                    "description": "APIVersion is the API version (i.e. \"core/v1\")"
                },
                "kind": {
                    "type": "string",
                    "description": "Kind is the kind (i.e. \"ComponentLog\")"
                },
                "metadata": {
                    "$ref": "#/definitions/octelium.api.main.meta.v1.LogMetadata",
                    "additionalProperties": false,
                    "description": "Metadata is the metadata"
                },
                "entry": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.ComponentLog.Entry",
                    "additionalProperties": false,
                    "description": "Entry is the Log entry information"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Component Log"
        },
        "octelium.api.main.core.v1.ComponentLog.Entry": {
            "properties": {
                "message": {
                    "type": "string"
                },
                "level": {
                    "enum": [
                        "LEVEL_UNSET",
                        "DEBUG",
                        "INFO",
                        "WARN",
                        "ERROR",
                        "PANIC",
                        "FATAL"
                    ],
                    "type": "string",
                    "title": "Level"
                },
                "component": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.ComponentLog.Entry.Component",
                    "additionalProperties": false
                },
                "fields": {
                    "additionalProperties": true,
                    "type": "object"
                },
                "function": {
                    "type": "string"
                },
                "file": {
                    "type": "string"
                },
                "line": {
                    "type": "integer"
                },
                "time": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Entry"
        },
        "octelium.api.main.core.v1.ComponentLog.Entry.Component": {
            "properties": {
                "namespace": {
                    "type": "string"
                },
                "uid": {
                    "type": "string"
                },
                "type": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Component"
        },
        "octelium.api.main.meta.v1.LogMetadata": {
            "properties": {
                "id": {
                    "type": "string",
                    "description": "ID is the unique ID for the log entry"
                },
                "createdAt": {
                    "type": "string",
                    "description": "CreatedAt is the timestamp of creation.",
                    "format": "date-time"
                },
                "actorRef": {
                    "$ref": "#/definitions/octelium.api.main.meta.v1.ObjectReference",
                    "additionalProperties": false,
                    "description": "Actor is the actor whose action triggered the log entry (i.e. the User, their Session and Device if available)"
                },
                "targetRef": {
                    "$ref": "#/definitions/octelium.api.main.meta.v1.ObjectReference",
                    "additionalProperties": false,
                    "description": "Target is the target of the action that triggered the log entry (e.g. the Service and its Namespace in the case of a SERVICE log entry)"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Log Metadata"
        },
        "octelium.api.main.meta.v1.ObjectReference": {
            "properties": {
                "apiVersion": {
                    "type": "string",
                    "description": "APIVersion is the API version of the reference resource"
                },
                "kind": {
                    "type": "string",
                    "description": "Kind is the resource kind. A kind is unique per an APIVersion."
                },
                "uid": {
                    "type": "string",
                    "description": "UID is the resource object UID. A UID is unique across the entire Cluster."
                },
                "name": {
                    "type": "string",
                    "description": "Name is the resource object name. A name is unique per a certain kind."
                },
                "resourceVersion": {
                    "type": "string",
                    "description": "ResourceVersion is the resourceVersion of the resource."
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Object Reference"
        }
    }
}