{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/CredentialToken",
    "definitions": {
        "CredentialToken": {
            "properties": {
                "authenticationToken": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.CredentialToken.AuthenticationToken",
                    "additionalProperties": false,
                    "description": "AuthenticationToken is the returned authentication token"
                },
                "oauth2Credentials": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.CredentialToken.OAuth2Credentials",
                    "additionalProperties": false,
                    "description": "OAuth2Credentials is the returned OAuth2 client credential"
                },
                "accessToken": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.CredentialToken.AccessToken",
                    "additionalProperties": false,
                    "description": "AccessToken is the returned access token"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "allOf": [
                {
                    "oneOf": [
                        {
                            "not": {
                                "anyOf": [
                                    {
                                        "required": [
                                            "authenticationToken"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "oauth2Credentials"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "accessToken"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "required": [
                                "authenticationToken"
                            ]
                        },
                        {
                            "required": [
                                "oauth2Credentials"
                            ]
                        },
                        {
                            "required": [
                                "accessToken"
                            ]
                        }
                    ]
                }
            ],
            "title": "Credential Token"
        },
        "octelium.api.main.core.v1.CredentialToken.AccessToken": {
            "properties": {
                "accessToken": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Access Token"
        },
        "octelium.api.main.core.v1.CredentialToken.AuthenticationToken": {
            "properties": {
                "authenticationToken": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Authentication Token"
        },
        "octelium.api.main.core.v1.CredentialToken.OAuth2Credentials": {
            "properties": {
                "clientID": {
                    "type": "string",
                    "description": "ClientID is the OAuth2 client ID"
                },
                "clientSecret": {
                    "type": "string",
                    "description": "ClientSecret is the OAuth2 client secret"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "O Auth 2 Credentials"
        }
    }
}