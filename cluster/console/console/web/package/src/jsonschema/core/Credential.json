{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/Credential",
    "definitions": {
        "Credential": {
            "properties": {
                "apiVersion": {
                    "type": "string",
                    "description": "APIVersion is the API version (i.e. \"core/v1\")"
                },
                "kind": {
                    "type": "string",
                    "description": "Kind is the resource name (i.e. `Credential`)."
                },
                "metadata": {
                    "$ref": "#/definitions/octelium.api.main.meta.v1.Metadata",
                    "additionalProperties": false,
                    "description": "octelium.api.main.meta.v1.Metadata is the object's metadata."
                },
                "spec": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Credential.Spec",
                    "additionalProperties": false,
                    "description": "Spec is the Credential specification."
                },
                "status": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Credential.Status",
                    "additionalProperties": false,
                    "description": "Status is the current status of the Credential."
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Credential"
        },
        "octelium.api.main.core.v1.Condition": {
            "properties": {
                "matchAny": {
                    "type": "boolean",
                    "description": "MatchAny matches anything"
                },
                "match": {
                    "type": "string",
                    "description": "Match contains a single CEL expression"
                },
                "all": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Condition.All",
                    "additionalProperties": false,
                    "description": "All acts as a logical AND operator on its list of CEL expressions"
                },
                "any": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Condition.Any",
                    "additionalProperties": false,
                    "description": "Any acts as a logical OR operator on its list of CEL expressions"
                },
                "not": {
                    "type": "string",
                    "description": "Not acts as a logical NOT operator of a single CEL expression"
                },
                "none": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Condition.None",
                    "additionalProperties": false,
                    "description": "None acts as a logical NOR operator on its list of CEL expressions (i.e. none of the expressions matches)"
                },
                "opa": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Condition.OPA",
                    "additionalProperties": false,
                    "description": "OPA contains an OPA (Open Policy Agent) Rego script"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "allOf": [
                {
                    "oneOf": [
                        {
                            "not": {
                                "anyOf": [
                                    {
                                        "required": [
                                            "matchAny"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "match"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "all"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "any"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "not"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "none"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "opa"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "required": [
                                "matchAny"
                            ]
                        },
                        {
                            "required": [
                                "match"
                            ]
                        },
                        {
                            "required": [
                                "all"
                            ]
                        },
                        {
                            "required": [
                                "any"
                            ]
                        },
                        {
                            "required": [
                                "not"
                            ]
                        },
                        {
                            "required": [
                                "none"
                            ]
                        },
                        {
                            "required": [
                                "opa"
                            ]
                        }
                    ]
                }
            ],
            "title": "Condition"
        },
        "octelium.api.main.core.v1.Condition.All": {
            "properties": {
                "of": {
                    "items": {
                        "$ref": "#/definitions/octelium.api.main.core.v1.Condition"
                    },
                    "additionalProperties": false,
                    "type": "array"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "All"
        },
        "octelium.api.main.core.v1.Condition.Any": {
            "properties": {
                "of": {
                    "items": {
                        "$ref": "#/definitions/octelium.api.main.core.v1.Condition"
                    },
                    "additionalProperties": false,
                    "type": "array",
                    "description": "Expressions is the list of CEL expressions"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Any"
        },
        "octelium.api.main.core.v1.Condition.None": {
            "properties": {
                "of": {
                    "items": {
                        "$ref": "#/definitions/octelium.api.main.core.v1.Condition"
                    },
                    "additionalProperties": false,
                    "type": "array",
                    "description": "Expressions is the list of CEL expressions"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "None"
        },
        "octelium.api.main.core.v1.Condition.OPA": {
            "properties": {
                "inline": {
                    "type": "string",
                    "description": "Inline is the OPA Rego script directly provided as a string"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "allOf": [
                {
                    "oneOf": [
                        {
                            "not": {
                                "anyOf": [
                                    {
                                        "required": [
                                            "inline"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "required": [
                                "inline"
                            ]
                        }
                    ]
                }
            ],
            "title": "OPA"
        },
        "octelium.api.main.core.v1.Credential.Spec": {
            "properties": {
                "type": {
                    "enum": [
                        "TYPE_UNKNOWN",
                        "AUTH_TOKEN",
                        "OAUTH2",
                        "ACCESS_TOKEN"
                    ],
                    "type": "string",
                    "title": "Type"
                },
                "user": {
                    "type": "string"
                },
                "maxAuthentications": {
                    "type": "integer",
                    "description": "MaxAuthentications sets the max number of authentications permitted by this Credential."
                },
                "expiresAt": {
                    "type": "string",
                    "description": "ExpiresAt is the timestamp at which the token expires.",
                    "format": "date-time"
                },
                "sessionType": {
                    "enum": [
                        "TYPE_UNKNOWN",
                        "CLIENT",
                        "CLIENTLESS"
                    ],
                    "type": "string",
                    "title": "Type"
                },
                "authorization": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Credential.Spec.Authorization",
                    "additionalProperties": false
                },
                "isDisabled": {
                    "type": "boolean",
                    "description": "IsDisabled disables the Credential and prevents authentication via it."
                },
                "autoDelete": {
                    "type": "boolean",
                    "description": "AutoDelete auto-deletes the Credentials once the max number of authentications has been reached."
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Spec"
        },
        "octelium.api.main.core.v1.Credential.Spec.Authorization": {
            "properties": {
                "policies": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array",
                    "description": "Policies is the list of standalone Policies"
                },
                "inlinePolicies": {
                    "items": {
                        "$ref": "#/definitions/octelium.api.main.core.v1.InlinePolicy"
                    },
                    "additionalProperties": false,
                    "type": "array",
                    "description": "InlinePolicies is the list of inline Policies"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Authorization"
        },
        "octelium.api.main.core.v1.Credential.Status": {
            "properties": {
                "userRef": {
                    "$ref": "#/definitions/octelium.api.main.meta.v1.ObjectReference",
                    "additionalProperties": false,
                    "description": "UserRef is the reference to the User who the Credential is created for"
                },
                "id": {
                    "type": "string"
                },
                "tokenID": {
                    "type": "string"
                },
                "lastRotationAt": {
                    "type": "string",
                    "format": "date-time"
                },
                "totalRotations": {
                    "type": "integer"
                },
                "totalAuthentications": {
                    "type": "integer"
                },
                "isLocked": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Status"
        },
        "octelium.api.main.core.v1.InlinePolicy": {
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Name is the name of the inline Policy"
                },
                "spec": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Policy.Spec",
                    "additionalProperties": false,
                    "description": "Spec is the Policy spec"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Inline Policy"
        },
        "octelium.api.main.core.v1.Policy.Spec": {
            "properties": {
                "rules": {
                    "items": {
                        "$ref": "#/definitions/octelium.api.main.core.v1.Policy.Spec.Rule"
                    },
                    "additionalProperties": false,
                    "type": "array",
                    "description": "Rules is the list of Policy rules"
                },
                "enforcementRules": {
                    "items": {
                        "$ref": "#/definitions/octelium.api.main.core.v1.Policy.Spec.EnforcementRule"
                    },
                    "additionalProperties": false,
                    "type": "array",
                    "description": "EnforcementRules is the list of enforcement rules that are typically used as a precondition for using the Policy rules. You can simply extract your shared conditions from your rules and write them instead inside enforcementRules for better performance and readability"
                },
                "attrs": {
                    "additionalProperties": true,
                    "type": "object"
                },
                "isDisabled": {
                    "type": "boolean",
                    "description": "IsDisabled disables (i.e. deactivates) the Policy. You can use this to temporarily disable enforcing the Policy altogether instead of having to delete it or de-attach it from the different Resources attaching it."
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Spec"
        },
        "octelium.api.main.core.v1.Policy.Spec.EnforcementRule": {
            "properties": {
                "condition": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Condition",
                    "additionalProperties": false,
                    "description": "Condition is the enforcement rule's Condition"
                },
                "effect": {
                    "enum": [
                        "EFFECT_UNKNOWN",
                        "ENFORCE",
                        "IGNORE"
                    ],
                    "type": "string",
                    "title": "Effect"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Enforcement Rule"
        },
        "octelium.api.main.core.v1.Policy.Spec.Rule": {
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Name is an optional name for the rule. It is currently useful in Logs to understand which rule triggered the Policy."
                },
                "condition": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Condition",
                    "additionalProperties": false,
                    "description": "Condition is the rule's Condition that must match in order for the rule, and subsequently the Policy as whole, to match"
                },
                "effect": {
                    "enum": [
                        "EFFECT_UNKNOWN",
                        "ALLOW",
                        "DENY"
                    ],
                    "type": "string",
                    "title": "Effect"
                },
                "priority": {
                    "type": "integer",
                    "description": "Priority is an integer that sets the rule priority level. The lower the number, the higher the priority. Currently the range of numbers is between -4 (i.e. the highest priority) and 4 (i.e. the lowest priority)."
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Rule"
        },
        "octelium.api.main.meta.v1.Metadata": {
            "properties": {
                "uid": {
                    "type": "string",
                    "description": "UID is the unique UUID value for the object assigned by the Cluster. Read-only."
                },
                "name": {
                    "type": "string",
                    "description": "Name is the name of the object. It must be unique within a certain API/Version/Kind tuple."
                },
                "createdAt": {
                    "type": "string",
                    "description": "CreatedAt is the timestamp of creation of the object. Read-only.",
                    "format": "date-time"
                },
                "updatedAt": {
                    "type": "string",
                    "description": "UpdatedAt is the timestamp of when the object was last updated. Read-only.",
                    "format": "date-time"
                },
                "displayName": {
                    "type": "string",
                    "description": "DisplayName is the name that can be shown publicly for the object. Doesn't need to be unique."
                },
                "description": {
                    "type": "string",
                    "description": "Description is used to describe the object in a short sentence. Maximum characters are 1000."
                },
                "labels": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "Labels is a map of string keys and values to organize objects."
                },
                "tags": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array",
                    "description": "Tags is an optional array of tags that classify the Resource."
                },
                "annotations": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "Labels is a map of string keys and values that can be used to store metadata about the object."
                },
                "picURL": {
                    "type": "string",
                    "description": "PicURL is the Picture URL of the resource."
                },
                "resourceVersion": {
                    "type": "string",
                    "description": "ResourceVersion is a unique ID that represent the current version of the resource object. Used by the Cluster to detect updates."
                },
                "lastResourceVersion": {
                    "type": "string",
                    "description": "LastResourceVersion is the ResourceVersion of the last update of the Resource."
                },
                "actorRef": {
                    "$ref": "#/definitions/octelium.api.main.meta.v1.ObjectReference",
                    "additionalProperties": false,
                    "description": "ActorRef is the object reference to the Actor resource, typically a Session, who is responsible for the current resource change. If ActorRef is not set, then the current change of the resource was done by the Cluster"
                },
                "actorOperation": {
                    "type": "string",
                    "description": "ActorOperation is the gRPC full method triggered by the actorRef to modify the Resource"
                },
                "isSystem": {
                    "type": "boolean",
                    "description": "IsSystem means that the resource is created by the Cluster and it cannot be managed by the administrators. Read-only."
                },
                "specLabels": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "SpecLabels is map used internally by the Cluster for quick searches among lists of objects. Read-only."
                },
                "isUserHidden": {
                    "type": "boolean",
                    "description": "IsUserHidden means that the resource object is hidden from ordinary Users and should not be exposed via the User APIs."
                },
                "isSystemHidden": {
                    "type": "boolean",
                    "description": "IsSystemHidden means that the resource object is hidden by the Cluster and should not be exposed via the APIs."
                },
                "systemLabels": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "SystemLabels is a similar map to specLabels. Used only by the Cluster."
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Metadata"
        },
        "octelium.api.main.meta.v1.ObjectReference": {
            "properties": {
                "apiVersion": {
                    "type": "string",
                    "description": "APIVersion is the API version of the reference resource"
                },
                "kind": {
                    "type": "string",
                    "description": "Kind is the resource kind. A kind is unique per an APIVersion."
                },
                "uid": {
                    "type": "string",
                    "description": "UID is the resource object UID. A UID is unique across the entire Cluster."
                },
                "name": {
                    "type": "string",
                    "description": "Name is the resource object name. A name is unique per a certain kind."
                },
                "resourceVersion": {
                    "type": "string",
                    "description": "ResourceVersion is the resourceVersion of the resource."
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Object Reference"
        }
    }
}