{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/IdentityProvider",
    "definitions": {
        "IdentityProvider": {
            "properties": {
                "apiVersion": {
                    "type": "string",
                    "description": "APIVersion is the API version (i.e. \"core/v1\")"
                },
                "kind": {
                    "type": "string",
                    "description": "Kind is the resource name (i.e. `User`)."
                },
                "metadata": {
                    "$ref": "#/definitions/octelium.api.main.meta.v1.Metadata",
                    "additionalProperties": false,
                    "description": "Metadata is the object's metadata."
                },
                "spec": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.IdentityProvider.Spec",
                    "additionalProperties": false,
                    "description": "Spec is the User specification."
                },
                "status": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.IdentityProvider.Status",
                    "additionalProperties": false,
                    "description": "Status is the current status of the User."
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Identity Provider"
        },
        "octelium.api.main.core.v1.Condition": {
            "properties": {
                "matchAny": {
                    "type": "boolean",
                    "description": "MatchAny matches anything"
                },
                "match": {
                    "type": "string",
                    "description": "Match contains a single CEL expression"
                },
                "all": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Condition.All",
                    "additionalProperties": false,
                    "description": "All acts as a logical AND operator on its list of CEL expressions"
                },
                "any": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Condition.Any",
                    "additionalProperties": false,
                    "description": "Any acts as a logical OR operator on its list of CEL expressions"
                },
                "not": {
                    "type": "string",
                    "description": "Not acts as a logical NOT operator of a single CEL expression"
                },
                "none": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Condition.None",
                    "additionalProperties": false,
                    "description": "None acts as a logical NOR operator on its list of CEL expressions (i.e. none of the expressions matches)"
                },
                "opa": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Condition.OPA",
                    "additionalProperties": false,
                    "description": "OPA contains an OPA (Open Policy Agent) Rego script"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "allOf": [
                {
                    "oneOf": [
                        {
                            "not": {
                                "anyOf": [
                                    {
                                        "required": [
                                            "matchAny"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "match"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "all"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "any"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "not"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "none"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "opa"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "required": [
                                "matchAny"
                            ]
                        },
                        {
                            "required": [
                                "match"
                            ]
                        },
                        {
                            "required": [
                                "all"
                            ]
                        },
                        {
                            "required": [
                                "any"
                            ]
                        },
                        {
                            "required": [
                                "not"
                            ]
                        },
                        {
                            "required": [
                                "none"
                            ]
                        },
                        {
                            "required": [
                                "opa"
                            ]
                        }
                    ]
                }
            ],
            "title": "Condition"
        },
        "octelium.api.main.core.v1.Condition.All": {
            "properties": {
                "of": {
                    "items": {
                        "$ref": "#/definitions/octelium.api.main.core.v1.Condition"
                    },
                    "additionalProperties": false,
                    "type": "array"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "All"
        },
        "octelium.api.main.core.v1.Condition.Any": {
            "properties": {
                "of": {
                    "items": {
                        "$ref": "#/definitions/octelium.api.main.core.v1.Condition"
                    },
                    "additionalProperties": false,
                    "type": "array",
                    "description": "Expressions is the list of CEL expressions"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Any"
        },
        "octelium.api.main.core.v1.Condition.None": {
            "properties": {
                "of": {
                    "items": {
                        "$ref": "#/definitions/octelium.api.main.core.v1.Condition"
                    },
                    "additionalProperties": false,
                    "type": "array",
                    "description": "Expressions is the list of CEL expressions"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "None"
        },
        "octelium.api.main.core.v1.Condition.OPA": {
            "properties": {
                "inline": {
                    "type": "string",
                    "description": "Inline is the OPA Rego script directly provided as a string"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "allOf": [
                {
                    "oneOf": [
                        {
                            "not": {
                                "anyOf": [
                                    {
                                        "required": [
                                            "inline"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "required": [
                                "inline"
                            ]
                        }
                    ]
                }
            ],
            "title": "OPA"
        },
        "octelium.api.main.core.v1.IdentityProvider.Spec": {
            "properties": {
                "isDisabled": {
                    "type": "boolean",
                    "description": "IsDisabled disables the IdentityProvider"
                },
                "displayName": {
                    "type": "string",
                    "description": "DisplayName is the public IdentityProvider display name that Users see when they try to authenticate"
                },
                "aalRules": {
                    "items": {
                        "$ref": "#/definitions/octelium.api.main.core.v1.IdentityProvider.Spec.AALRule"
                    },
                    "additionalProperties": false,
                    "type": "array",
                    "description": "AALRules is the list of Authenticator assurance level rules"
                },
                "disableEmailAsIdentity": {
                    "type": "boolean",
                    "description": "DisableEmailAsIdentity disables using the email field in the User spec as an identity to be matched against the information returned by the IdentityProvider during the authentication flow. In other words, if this field is set to true, then you must create an identity for the IdentityProvider with an explicit identifier in the User spec. This field is only meaningful for web-based IdentityProviders only (i.e. the ones with types \"github\", \"oidc\" or \"saml\")."
                },
                "postAuthenticationRules": {
                    "items": {
                        "$ref": "#/definitions/octelium.api.main.core.v1.IdentityProvider.Spec.PostAuthenticationRule"
                    },
                    "additionalProperties": false,
                    "type": "array"
                },
                "github": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.IdentityProvider.Spec.Github",
                    "additionalProperties": false,
                    "description": "Github sets the Github OAuth2 provider specific options."
                },
                "oidc": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.IdentityProvider.Spec.OIDC",
                    "additionalProperties": false,
                    "description": "OIDC sets the OpenID Connect provider options."
                },
                "saml": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.IdentityProvider.Spec.SAML",
                    "additionalProperties": false,
                    "description": "SAML sets the SAML 2.0 identity provider options."
                },
                "oidcIdentityToken": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.IdentityProvider.Spec.OIDCIdentityToken",
                    "additionalProperties": false,
                    "description": "OIDCIdentityToken sets the OIDC-based assertion options used for WORKLOAD User authentication"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "allOf": [
                {
                    "oneOf": [
                        {
                            "not": {
                                "anyOf": [
                                    {
                                        "required": [
                                            "github"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "oidc"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "saml"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "oidcIdentityToken"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "required": [
                                "github"
                            ]
                        },
                        {
                            "required": [
                                "oidc"
                            ]
                        },
                        {
                            "required": [
                                "saml"
                            ]
                        },
                        {
                            "required": [
                                "oidcIdentityToken"
                            ]
                        }
                    ]
                }
            ],
            "title": "Spec"
        },
        "octelium.api.main.core.v1.IdentityProvider.Spec.AALRule": {
            "properties": {
                "condition": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Condition",
                    "additionalProperties": false,
                    "description": "Condition is the rule's condition"
                },
                "aal": {
                    "enum": [
                        "AAL_UNSET",
                        "AAL1",
                        "AAL2",
                        "AAL3"
                    ],
                    "type": "string",
                    "title": "AAL"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "AAL Rule"
        },
        "octelium.api.main.core.v1.IdentityProvider.Spec.Github": {
            "properties": {
                "clientID": {
                    "type": "string"
                },
                "clientSecret": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.IdentityProvider.Spec.Github.ClientSecret",
                    "additionalProperties": false
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Github"
        },
        "octelium.api.main.core.v1.IdentityProvider.Spec.Github.ClientSecret": {
            "properties": {
                "fromSecret": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "allOf": [
                {
                    "oneOf": [
                        {
                            "not": {
                                "anyOf": [
                                    {
                                        "required": [
                                            "fromSecret"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "required": [
                                "fromSecret"
                            ]
                        }
                    ]
                }
            ],
            "title": "Client Secret"
        },
        "octelium.api.main.core.v1.IdentityProvider.Spec.OIDC": {
            "properties": {
                "clientID": {
                    "type": "string",
                    "description": "ClientID is the OIDC OAuth2 client ID"
                },
                "clientSecret": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.IdentityProvider.Spec.OIDC.ClientSecret",
                    "additionalProperties": false,
                    "description": "ClientSecret is the OIDC OAuth2 client secret"
                },
                "issuerURL": {
                    "type": "string",
                    "description": "IssuerURL is the issuer URL where the OIDC configuration can be obtained automatically by adding this IssuerURL to the path \"/.well-known/openid-configuration\""
                },
                "scopes": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array",
                    "description": "Scopes are the additional scopes to `openid`. The default value is [`profile`, `email`]."
                },
                "identifierClaim": {
                    "type": "string",
                    "description": "IdentifierClaim overrides the default claim (i.e. currently `email`) as the claim whose value is used as the identifier."
                },
                "checkEmailVerified": {
                    "type": "boolean",
                    "description": "CheckEmailVerified checks that the `email_verified` claim is set to true."
                },
                "useUserInfoEndpoint": {
                    "type": "boolean",
                    "description": "UseUserInfoEndpoint obtains the claims via the UserInfo endpoint."
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "OIDC"
        },
        "octelium.api.main.core.v1.IdentityProvider.Spec.OIDC.ClientSecret": {
            "properties": {
                "fromSecret": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "allOf": [
                {
                    "oneOf": [
                        {
                            "not": {
                                "anyOf": [
                                    {
                                        "required": [
                                            "fromSecret"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "required": [
                                "fromSecret"
                            ]
                        }
                    ]
                }
            ],
            "title": "Client Secret"
        },
        "octelium.api.main.core.v1.IdentityProvider.Spec.OIDCIdentityToken": {
            "properties": {
                "issuerURL": {
                    "type": "string"
                },
                "jwksURL": {
                    "type": "string"
                },
                "jwksContent": {
                    "type": "string"
                },
                "issuer": {
                    "type": "string"
                },
                "audience": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "allOf": [
                {
                    "oneOf": [
                        {
                            "not": {
                                "anyOf": [
                                    {
                                        "required": [
                                            "issuerURL"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "jwksURL"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "jwksContent"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "required": [
                                "issuerURL"
                            ]
                        },
                        {
                            "required": [
                                "jwksURL"
                            ]
                        },
                        {
                            "required": [
                                "jwksContent"
                            ]
                        }
                    ]
                }
            ],
            "title": "OIDC Identity Token"
        },
        "octelium.api.main.core.v1.IdentityProvider.Spec.PostAuthenticationRule": {
            "properties": {
                "condition": {
                    "$ref": "#/definitions/octelium.api.main.core.v1.Condition",
                    "additionalProperties": false
                },
                "effect": {
                    "enum": [
                        "EFFECT_UNKNOWN",
                        "ALLOW",
                        "DENY"
                    ],
                    "type": "string",
                    "title": "Effect"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Post Authentication Rule"
        },
        "octelium.api.main.core.v1.IdentityProvider.Spec.SAML": {
            "properties": {
                "metadataURL": {
                    "type": "string",
                    "description": "MetadataURL is the SAML 2.0 metadata URL"
                },
                "metadata": {
                    "type": "string",
                    "description": "Metadata is the inline metadata XML content"
                },
                "entityID": {
                    "type": "string",
                    "description": "EntityID is the entity ID. If not set, then the value \"https://\u003cCLUSTER_DOMAIN\u003e\" is used as the default entity ID."
                },
                "identifierAttribute": {
                    "type": "string",
                    "description": "IdentifierAttribute is the attribute of the identifier used for authentication. If not set, then the default value \"http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress\" is used instead."
                },
                "forceAuthn": {
                    "type": "boolean",
                    "description": "ForceAuthn forces re-authentication by the IdP even if the user has a valid SSO session"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "allOf": [
                {
                    "oneOf": [
                        {
                            "not": {
                                "anyOf": [
                                    {
                                        "required": [
                                            "metadataURL"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "metadata"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "required": [
                                "metadataURL"
                            ]
                        },
                        {
                            "required": [
                                "metadata"
                            ]
                        }
                    ]
                }
            ],
            "title": "SAML"
        },
        "octelium.api.main.core.v1.IdentityProvider.Status": {
            "properties": {
                "type": {
                    "enum": [
                        "TYPE_UNKNOWN",
                        "GITHUB",
                        "OIDC",
                        "SAML",
                        "OIDC_IDENTITY_TOKEN"
                    ],
                    "type": "string",
                    "title": "Type"
                },
                "isLocked": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Status"
        },
        "octelium.api.main.meta.v1.Metadata": {
            "properties": {
                "uid": {
                    "type": "string",
                    "description": "UID is the unique UUID value for the object assigned by the Cluster. Read-only."
                },
                "name": {
                    "type": "string",
                    "description": "Name is the name of the object. It must be unique within a certain API/Version/Kind tuple."
                },
                "createdAt": {
                    "type": "string",
                    "description": "CreatedAt is the timestamp of creation of the object. Read-only.",
                    "format": "date-time"
                },
                "updatedAt": {
                    "type": "string",
                    "description": "UpdatedAt is the timestamp of when the object was last updated. Read-only.",
                    "format": "date-time"
                },
                "displayName": {
                    "type": "string",
                    "description": "DisplayName is the name that can be shown publicly for the object. Doesn't need to be unique."
                },
                "description": {
                    "type": "string",
                    "description": "Description is used to describe the object in a short sentence. Maximum characters are 1000."
                },
                "labels": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "Labels is a map of string keys and values to organize objects."
                },
                "tags": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array",
                    "description": "Tags is an optional array of tags that classify the Resource."
                },
                "annotations": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "Labels is a map of string keys and values that can be used to store metadata about the object."
                },
                "picURL": {
                    "type": "string",
                    "description": "PicURL is the Picture URL of the resource."
                },
                "resourceVersion": {
                    "type": "string",
                    "description": "ResourceVersion is a unique ID that represent the current version of the resource object. Used by the Cluster to detect updates."
                },
                "lastResourceVersion": {
                    "type": "string",
                    "description": "LastResourceVersion is the ResourceVersion of the last update of the Resource."
                },
                "actorRef": {
                    "$ref": "#/definitions/octelium.api.main.meta.v1.ObjectReference",
                    "additionalProperties": false,
                    "description": "ActorRef is the object reference to the Actor resource, typically a Session, who is responsible for the current resource change. If ActorRef is not set, then the current change of the resource was done by the Cluster"
                },
                "actorOperation": {
                    "type": "string",
                    "description": "ActorOperation is the gRPC full method triggered by the actorRef to modify the Resource"
                },
                "isSystem": {
                    "type": "boolean",
                    "description": "IsSystem means that the resource is created by the Cluster and it cannot be managed by the administrators. Read-only."
                },
                "specLabels": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "SpecLabels is map used internally by the Cluster for quick searches among lists of objects. Read-only."
                },
                "isUserHidden": {
                    "type": "boolean",
                    "description": "IsUserHidden means that the resource object is hidden from ordinary Users and should not be exposed via the User APIs."
                },
                "isSystemHidden": {
                    "type": "boolean",
                    "description": "IsSystemHidden means that the resource object is hidden by the Cluster and should not be exposed via the APIs."
                },
                "systemLabels": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "SystemLabels is a similar map to specLabels. Used only by the Cluster."
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Metadata"
        },
        "octelium.api.main.meta.v1.ObjectReference": {
            "properties": {
                "apiVersion": {
                    "type": "string",
                    "description": "APIVersion is the API version of the reference resource"
                },
                "kind": {
                    "type": "string",
                    "description": "Kind is the resource kind. A kind is unique per an APIVersion."
                },
                "uid": {
                    "type": "string",
                    "description": "UID is the resource object UID. A UID is unique across the entire Cluster."
                },
                "name": {
                    "type": "string",
                    "description": "Name is the resource object name. A name is unique per a certain kind."
                },
                "resourceVersion": {
                    "type": "string",
                    "description": "ResourceVersion is the resourceVersion of the resource."
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Object Reference"
        }
    }
}