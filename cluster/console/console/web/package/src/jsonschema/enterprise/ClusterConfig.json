                    "$ref": "#/definitions/octelium.api.main.enterprise.v1.ClusterConfig.Status.UpgradeRequest",
                    "additionalProperties": false
                },
                "lastUpgradeRequests": {
                    "items": {
                        "$ref": "#/definitions/octelium.api.main.enterprise.v1.ClusterConfig.Status.UpgradeRequest"
                    },
                    "additionalProperties": false,
                    "type": "array"
                },
                "totalSuccessfulUpgrades": {
                    "type": "integer"
                },
                "totalFailedUpgrades": {
                    "type": "integer"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Status"
        },
        "octelium.api.main.enterprise.v1.ClusterConfig.Status.UpgradeRequest": {
            "properties": {
                "createdAt": {
                    "type": "string",
                    "format": "date-time"
                },
                "state": {
                    "enum": [
                        "STATE_UNSET",
                        "UPGRADE_REQUESTED",
                        "UPGRADING",
                        "SUCCESS",
                        "FAILED"
                    ],
                    "type": "string",
                    "title": "State"
                },
                "doneAt": {
                    "type": "string",
                    "format": "date-time"
                },
                "request": {
                    "$ref": "#/definitions/octelium.api.main.enterprise.v1.UpgradeClusterRequest.Request",
