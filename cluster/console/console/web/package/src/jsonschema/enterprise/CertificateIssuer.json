                },
                "email": {
                    "type": "string",
                    "description": "Email is the email provided to your ACME provider (e.g. `contact@example.com`). Required."
                },
                "solver": {
                    "$ref": "#/definitions/octelium.api.main.enterprise.v1.CertificateIssuer.Spec.ACME.Solver",
                    "additionalProperties": false,
                    "description": "Solver is the  challenge solver."
