                "lastResourceVersion": {
                    "type": "string",
                    "description": "LastResourceVersion is the ResourceVersion of the last update of the Resource."
                },
                "actorRef": {
                    "$ref": "#/definitions/octelium.api.main.meta.v1.ObjectReference",
                    "additionalProperties": false,
                    "description": "ActorRef is the object reference to the Actor resource, typically a Session, who is responsible for the current resource change. If ActorRef is not set, then the current change of the resource was done by the Cluster"
                },
                "actorOperation": {
                    "type": "string",
                    "description": "ActorOperation is the gRPC full method triggered by the actorRef to modify the Resource"
                },
                "isSystem": {
                    "type": "boolean",
                    "description": "IsSystem means that the resource is created by the Cluster and it cannot be managed by the administrators. Read-only."
                },
                "specLabels": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "SpecLabels is map used internally by the Cluster for quick searches among lists of objects. Read-only."
                },
                "isUserHidden": {
                    "type": "boolean",
                    "description": "IsUserHidden means that the resource object is hidden from ordinary Users and should not be exposed via the User APIs."
                },
                "isSystemHidden": {
                    "type": "boolean",
                    "description": "IsSystemHidden means that the resource object is hidden by the Cluster and should not be exposed via the APIs."
                },
                "systemLabels": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "SystemLabels is a similar map to specLabels. Used only by the Cluster."
                }
