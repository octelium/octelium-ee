                    "$ref": "#/definitions/octelium.api.main.meta.v1.Metadata",
                    "additionalProperties": false,
                    "description": "octelium.api.main.meta.v1.Metadata is the object's metadata."
                },
                "spec": {
                    "$ref": "#/definitions/octelium.api.main.enterprise.v1.CertificateIssuer.Spec",
                    "additionalProperties": false,
                    "description": "Spec is the Secret specification."
                },
                "status": {
                    "$ref": "#/definitions/octelium.api.main.enterprise.v1.CertificateIssuer.Status",
                    "additionalProperties": false,
                    "description": "Status is the current status of the Secret."
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Certificate Issuer"
        },
        "octelium.api.main.enterprise.v1.CertificateIssuer.Spec": {
