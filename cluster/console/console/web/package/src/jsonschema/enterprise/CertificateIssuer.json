                "acme": {
                    "$ref": "#/definitions/octelium.api.main.enterprise.v1.CertificateIssuer.Spec.ACME",
                    "additionalProperties": false
                }
            },
            "additionalProperties": false,
            "type": "object",
            "allOf": [
                {
                    "oneOf": [
                        {
                            "not": {
                                "anyOf": [
                                    {
                                        "required": [
                                            "acme"
                                        ]
                                    }
                                ]
                            }
                        },
                        {
                            "required": [
                                "acme"
                            ]
                        }
                    ]
